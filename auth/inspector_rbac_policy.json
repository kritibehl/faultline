{
  "roles": {
    "viewer": {
      "allowed_endpoints": ["/health", "/leases"]
    },
    "operator": {
      "allowed_endpoints": ["/health", "/leases", "/metrics", "/trace/export"]
    },
    "admin": {
      "allowed_endpoints": ["/health", "/leases", "/metrics", "/trace/export"]
    }
  },
  "auth_model": "api_key_or_bearer_token",
  "safe_claim": "demo API-key/RBAC policy artifact, not enterprise RBAC"
}
